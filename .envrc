export DIRENV_WARN_TIMEOUT=60s

# ── Agent-exception secrets (canonical, INSPR-689) ────────────────────────
# Auto-source every materialized .env file in the agent-secrets dir.
# Filenames map to env-var names (PPMAPIKEY.env → $PPMAPIKEY, GH_TOKEN.env →
# $GH_TOKEN, etc.) — see modules/shared/agent-secrets.nix.
#
# `set -a` is required because the .env files use plain `KEY=value` form
# (no explicit `export`) — `set -a` auto-exports any var set in the
# enclosed block, which is what direnv needs to surface them.
if [[ -d ~/Secrets/age/decrypted/agents ]]; then
    set -a
    for f in ~/Secrets/age/decrypted/agents/*.env; do
        [[ -f "$f" ]] && source "$f"
    done
    set +a
fi

# ── GitHub token (legacy fallback — Tier 4 macOS Keychain) ────────────────
# Keep for hosts that haven't yet adopted inspr.secrets.agents (e.g. older
# Macs pre-INSPR migration). Skipped if the agent-secrets pipeline already
# set GH_TOKEN above.
if [[ -z "${GH_TOKEN:-}" ]]; then
    export GH_TOKEN=$(security find-generic-password -s "gh-token-markus-barta" -w 2>/dev/null)
fi

eval "$(devenv direnvrc)"
use devenv
