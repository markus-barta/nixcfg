export DIRENV_WARN_TIMEOUT=60s

# ── Agent-exception secrets (canonical path: INSPR-164 + INSPR-689) ───────
# Auto-source every materialized KEY=VALUE env file in the agent-secrets dir.
# Filenames map to env-var names (PPMAPIKEY.env → $PPMAPIKEY, GH_TOKEN.env →
# $GH_TOKEN, etc.) — see inspr-modules' agent-secrets HM module.
#
# `set -a` is required because the .env files use plain `KEY=value` form
# (no explicit `export`) — `set -a` auto-exports any var set in the
# enclosed block, which is what direnv needs to surface them.
#
# IMPORTANT (security): inspr.secrets.agents materializes ALL host secrets
# to this directory, including SSH PRIVATE KEYS that happen to use a `.env`
# extension (per INSPR-170's atelier userkey convention — `<host>-<atelier>-
# userkey.env`). Sourcing those into the shell prints the base64-encoded
# key contents to stderr ("command not found"), leaking key bytes to the
# terminal scrollback. **Always content-filter before sourcing.** The
# `head -c 64 | grep -qE ...` check below admits only files whose first
# bytes match the canonical KEY=VALUE format. Files starting with anything
# else (e.g. `-----BEGIN OPENSSH PRIVATE KEY-----`) are skipped silently.
# Follow-up doctrine: separate paths per content-type (env files vs SSH
# keys) so this defense doesn't have to live here. See INSPR-664+1.
if [[ -d ~/.inspr/secrets/agents ]]; then
  set -a
  for f in ~/.inspr/secrets/agents/*.env; do
    [[ -f "$f" ]] || continue
    # Content sniff: first 64 bytes must contain a `<UPPER_VAR>=` token
    # before any newline. Matches `PPMAPIKEY=…` etc. Rejects SSH keys
    # (start with `-----BEGIN`) and any other non-env content.
    if head -c 64 -- "$f" 2>/dev/null | grep -qE '^[A-Z_][A-Z0-9_]*='; then
      source "$f"
    fi
  done
  set +a
fi

# ── GitHub token (legacy fallback — Tier 4 macOS Keychain) ────────────────
# Keep for hosts that haven't yet adopted inspr.secrets.agents (e.g. older
# Macs pre-INSPR migration). Skipped if the agent-secrets pipeline already
# set GH_TOKEN above.
if [[ -z "${GH_TOKEN:-}" ]]; then
  export GH_TOKEN=$(security find-generic-password -s "gh-token-markus-barta" -w 2>/dev/null)
fi

eval "$(devenv direnvrc)"
use devenv
