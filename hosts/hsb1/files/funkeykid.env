# funkeykid Configuration for hsb1
# ACME BK03 Bluetooth Keyboard (QWERTZ layout)

# Device name (will be found automatically by name)
KEYBOARD_DEVICE=ACME BK03

# Sound directory
SOUND_DIR=/var/lib/funkeykid-sounds

# German (DE-AT) letter-sound mappings
# Note: Y/Z swapped for German QWERTZ keyboard layout
# (physical Y key sends KEY_Z scancode and vice versa)
KEY_A=sound:affe.mp3
KEY_B=sound:biene.mp3
KEY_C=sound:clown.mp3
KEY_D=sound:donner.mp3
KEY_E=sound:elefant.mp3
KEY_F=sound:frosch.mp3
KEY_G=sound:glocke.mp3
KEY_H=sound:hammer.mp3
KEY_I=sound:igel.mp3
KEY_J=sound:jaguar.mp3
KEY_K=sound:katze.mp3
KEY_L=sound:loewe.mp3
KEY_M=sound:kuh.mp3
KEY_N=sound:nachtigall.mp3
KEY_O=sound:orgel.mp3
KEY_P=sound:pferd.mp3
KEY_Q=sound:quaken.mp3
KEY_R=sound:regen.mp3
KEY_S=sound:schwein.mp3
KEY_T=sound:telefon.mp3
KEY_U=sound:uhu.mp3
KEY_V=sound:vogel.mp3
KEY_W=sound:wasser.mp3
KEY_X=sound:xylophon.mp3
KEY_Y=sound:yak.mp3
KEY_Z=sound:ziege.mp3

# Special keys
# SPACE = stop all sounds (hardcoded)
# +/- = volume control (handled by QWERTZ layout map)
# All other non-letter keys are ignored (no random sounds)
