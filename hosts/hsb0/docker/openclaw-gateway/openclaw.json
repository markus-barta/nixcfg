{
  "gateway": {
    "port": 18789,
    "bind": "lan",
    "mode": "local",
    "tls": { "enabled": true },
    "controlUi": {
      "allowedOrigins": [
        "https://192.168.1.99:18789",
        "https://100.64.0.6:18789"
      ]
    },
    "auth": { "mode": "token", "token": "${OPENCLAW_GATEWAY_TOKEN}" },
    "tailscale": { "mode": "off", "resetOnExit": false },
    "remote": {
      "url": "wss://100.64.0.6:18789",
      "tlsFingerprint": "C9:78:34:30:4C:25:3D:D5:58:C0:C3:DE:05:62:F0:03:83:33:3B:AB:03:06:45:13:98:29:B6:23:83:12:A5:E3"
    }
  },
  "agents": {
    "defaults": {
      "model": {
        "primary": "openrouter/anthropic/claude-sonnet-4.6",
        "fallbacks": [
          "openrouter/moonshotai/kimi-k2.5",
          "openrouter/google/gemini-3-flash-preview"
        ]
      },
      "models": {
        "arcee-ai/trinity-large-preview:free": { "alias": "trinitylgfree" },
        "arcee-ai/trinity-mini:free": { "alias": "trinityfree" },
        "deepseek/deepseek-v3.2": { "alias": "dsv32" },
        "minimax/minimax-m2.5:free": { "alias": "mini25free" },
        "nvidia/nemotron-3-super-120b-a12b:free": {
          "alias": "nemotron3super-free"
        },
        "openai/gpt-5.4-pro": { "alias": "gpt54pro" },
        "openrouter/anthropic/claude-opus-4.6": { "alias": "opus46" },
        "openrouter/anthropic/claude-sonnet-4.6": { "alias": "sonnet46" },
        "openrouter/google/gemini-3-flash-preview": { "alias": "gem3flash" },
        "openrouter/google/gemini-3.1-flash-lite-preview": {
          "alias": "gem31flashlite"
        },
        "openrouter/google/gemini-3.1-pro-preview": { "alias": "gem3pro" },
        "openrouter/healer-alpha": { "alias": "healer-alpha-free" },
        "openrouter/hunter-alpha": { "alias": "hunter-alpha-free" },
        "openrouter/minimax/minimax-m2.5": { "alias": "mini25" },
        "openrouter/moonshotai/kimi-k2.5": { "alias": "kimi25" },
        "openrouter/openai/gpt-5.4": { "alias": "gpt54" },
        "openrouter/qwen/qwen3.5-397b-a17b": { "alias": "qwen35" },
        "openrouter/stepfun/step-3.5-flash:free": { "alias": "step35free" },
        "openrouter/z-ai/glm-5": { "alias": "glm5" },
        "x-ai/grok-4.20-beta": { "alias": "grok420" },
        "x-ai/grok-4.20-multi-agent-beta": { "alias": "grok420ma" }
      },
      "maxConcurrent": 4,
      "subagents": { "maxConcurrent": 8 },
      "compaction": { "reserveTokensFloor": 5000 },
      "memorySearch": {
        "provider": "local",
        "fallback": "none"
      }
    },
    "list": [
      {
        "id": "merlin",
        "default": true,
        "name": "Merlin",
        "workspace": "/home/node/.openclaw/workspace-merlin",
        "agentDir": "/home/node/.openclaw/agents/merlin/agent"
      },
      {
        "id": "nimue",
        "name": "Nimue",
        "workspace": "/home/node/.openclaw/workspace-nimue",
        "agentDir": "/home/node/.openclaw/agents/nimue/agent"
      }
    ]
  },
  "bindings": [
    {
      "agentId": "merlin",
      "match": { "channel": "telegram", "accountId": "merlin" }
    },
    {
      "agentId": "nimue",
      "match": { "channel": "telegram", "accountId": "nimue" }
    }
  ],
  "channels": {
    "telegram": {
      "enabled": true,
      "accounts": {
        "merlin": {
          "botToken": "${TELEGRAM_BOT_TOKEN_MERLIN}",
          "dmPolicy": "pairing",
          "groupPolicy": "allowlist",
          "streaming": "partial"
        },
        "nimue": {
          "botToken": "${TELEGRAM_BOT_TOKEN_NIMUE}",
          "dmPolicy": "pairing",
          "groupPolicy": "allowlist",
          "streaming": "partial"
        }
      }
    }
  },
  "auth": {
    "profiles": {
      "openrouter:default": { "mode": "api_key", "provider": "openrouter" }
    }
  },
  "commands": {
    "native": "auto",
    "nativeSkills": "auto",
    "restart": true,
    "ownerDisplay": "raw"
  },
  "cron": { "enabled": true },
  "messages": {
    "ackReactionScope": "group-mentions",
    "tts": {
      "auto": "inbound",
      "provider": "elevenlabs",
      "modelOverrides": {
        "enabled": true,
        "allowProvider": false
      },
      "elevenlabs": {
        "voiceId": "DoY3AnZIeAWxlPZrUH7g",
        "modelId": "eleven_multilingual_v2",
        "languageCode": "de",
        "applyTextNormalization": "auto",
        "voiceSettings": {
          "stability": 0.5,
          "similarityBoost": 0.75,
          "style": 0.0,
          "useSpeakerBoost": true,
          "speed": 1.0
        }
      }
    }
  },
  "plugins": { "entries": { "telegram": { "enabled": true } } },
  "skills": { "install": { "nodeManager": "npm" } },
  "tools": {
    "agentToAgent": {
      "enabled": true,
      "allow": ["merlin", "nimue"]
    },
    "sessions": {
      "visibility": "all"
    },
    "web": { "search": { "enabled": true }, "fetch": { "enabled": true } },
    "media": {
      "audio": {
        "enabled": true,
        "models": [{ "provider": "groq", "model": "whisper-large-v3" }]
      }
    }
  }
}
