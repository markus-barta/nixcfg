{
  "gateway": {
    "port": 18789,
    "bind": "lan",
    "mode": "local",
    "tls": { "enabled": true },
    "controlUi": {
      "allowedOrigins": [
        "https://192.168.1.99:18789",
        "https://100.64.0.6:18789"
      ]
    },
    "auth": { "mode": "token", "token": "${OPENCLAW_GATEWAY_TOKEN}" },
    "tailscale": { "mode": "off", "resetOnExit": false },
    "remote": {
      "url": "wss://100.64.0.6:18789",
      "tlsFingerprint": "C9:78:34:30:4C:25:3D:D5:58:C0:C3:DE:05:62:F0:03:83:33:3B:AB:03:06:45:13:98:29:B6:23:83:12:A5:E3"
    }
  },
  "agents": {
    "defaults": {
      "model": {
        "primary": "openrouter/google/gemini-3-flash-preview",
        "fallbacks": ["openrouter/moonshotai/kimi-k2.5"]
      },
      "models": {
        "opencode-zen/glm-5-free": { "alias": "GLM-5 Free" },
        "opencode-zen/minimax-m2.5-free": { "alias": "MiniMax M2.5 Free" },
        "openrouter/anthropic/claude-opus-4.6": { "alias": "Claude Opus 4.6" },
        "openrouter/anthropic/claude-sonnet-4.6": {
          "alias": "Claude Sonnet 4.6"
        },
        "openrouter/google/gemini-3-flash-preview": {
          "alias": "Gemini 3 Flash Preview"
        },
        "openrouter/google/gemini-3.1-pro-preview": {
          "alias": "Gemini 3.1 Pro Preview"
        },
        "openrouter/moonshotai/kimi-k2.5": { "alias": "Kimi K2.5" },
        "openrouter/openai/gpt-5.2-codex": { "alias": "GPT-5.2-Codex" },
        "openrouter/z-ai/glm-5": { "alias": "GLM-5" }
      },
      "maxConcurrent": 4,
      "subagents": { "maxConcurrent": 8 },
      "compaction": { "reserveTokensFloor": 5000 },
      "memorySearch": {
        "provider": "local",
        "fallback": "none"
      }
    },
    "list": [
      {
        "id": "merlin",
        "default": true,
        "name": "Merlin",
        "workspace": "/home/node/.openclaw/workspace-merlin",
        "agentDir": "/home/node/.openclaw/agents/merlin/agent"
      },
      {
        "id": "nimue",
        "name": "Nimue",
        "workspace": "/home/node/.openclaw/workspace-nimue",
        "agentDir": "/home/node/.openclaw/agents/nimue/agent"
      }
    ]
  },
  "bindings": [
    {
      "agentId": "merlin",
      "match": { "channel": "telegram", "accountId": "merlin" }
    },
    {
      "agentId": "nimue",
      "match": { "channel": "telegram", "accountId": "nimue" }
    }
  ],
  "channels": {
    "telegram": {
      "enabled": true,
      "accounts": {
        "merlin": {
          "botToken": "${TELEGRAM_BOT_TOKEN_MERLIN}",
          "dmPolicy": "pairing",
          "groupPolicy": "allowlist",
          "streaming": "partial"
        },
        "nimue": {
          "botToken": "${TELEGRAM_BOT_TOKEN_NIMUE}",
          "dmPolicy": "pairing",
          "groupPolicy": "allowlist",
          "streaming": "partial"
        }
      }
    }
  },
  "auth": {
    "profiles": {
      "openrouter:default": { "mode": "api_key", "provider": "openrouter" }
    }
  },
  "commands": { "native": "auto", "nativeSkills": "auto" },
  "cron": { "enabled": true },
  "messages": {
    "ackReactionScope": "group-mentions",
    "tts": {
      "auto": "inbound",
      "provider": "elevenlabs",
      "modelOverrides": {
        "enabled": true,
        "allowProvider": false
      },
      "elevenlabs": {
        "voiceId": "DoY3AnZIeAWxlPZrUH7g",
        "modelId": "eleven_multilingual_v2",
        "languageCode": "de",
        "applyTextNormalization": "auto",
        "voiceSettings": {
          "stability": 0.5,
          "similarityBoost": 0.75,
          "style": 0.0,
          "useSpeakerBoost": true,
          "speed": 1.0
        }
      }
    }
  },
  "plugins": { "entries": { "telegram": { "enabled": true } } },
  "skills": { "install": { "nodeManager": "npm" } },
  "tools": {
    "agentToAgent": {
      "enabled": true,
      "allow": ["merlin", "nimue"]
    },
    "sessions": {
      "visibility": "all"
    },
    "web": { "search": { "enabled": true }, "fetch": { "enabled": true } },
    "media": {
      "audio": {
        "enabled": true,
        "models": [{ "provider": "groq", "model": "whisper-large-v3" }]
      }
    }
  }
}
