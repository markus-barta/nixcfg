{
  "auth": {
    "profiles": {
      "openrouter:default": {
        "provider": "openrouter",
        "mode": "api_key"
      }
    }
  },
  "agents": {
    "defaults": {
      "model": {
        "primary": "openrouter/anthropic/claude-sonnet-4.6",
        "fallbacks": [
          "openrouter/moonshotai/kimi-k2.5",
          "openrouter/google/gemini-3-flash-preview"
        ]
      },
      "models": {
        "openrouter/stepfun/step-3.5-flash:free": {
          "alias": "step35free"
        },
        "openrouter/moonshotai/kimi-k2.5": {
          "alias": "kimi25"
        },
        "openrouter/z-ai/glm-5": {
          "alias": "glm5"
        },
        "openrouter/minimax/minimax-m2.5": {
          "alias": "mini25"
        },
        "openrouter/qwen/qwen3.5-397b-a17b": {
          "alias": "qwen35"
        },
        "openrouter/anthropic/claude-sonnet-4.6": {
          "alias": "sonnet46"
        },
        "openrouter/anthropic/claude-opus-4.6": {
          "alias": "opus46"
        },
        "openrouter/openai/gpt-5.2": {
          "alias": "gpt52"
        },
        "openrouter/google/gemini-3.1-pro-preview": {
          "alias": "gem3pro"
        },
        "openrouter/google/gemini-3-flash-preview": {
          "alias": "gem3flash"
        }
      },
      "workspace": "/home/node/.openclaw/workspace",
      "compaction": {
        "mode": "safeguard"
      },
      "maxConcurrent": 4,
      "subagents": {
        "maxConcurrent": 8
      },
      "memorySearch": {
        "provider": "local",
        "fallback": "none"
      }
    },
    "list": [
      {
        "id": "main",
        "identity": {
          "name": "Percaival",
          "theme": "helpful AI butler with a poetic technical vibe",
          "emoji": "⚔️"
        },
        "groupChat": {
          "mentionPatterns": ["@Percaival", "@Percai", "@Percy", "Percaival"]
        }
      }
    ]
  },
  "tools": {
    "agentToAgent": {
      "enabled": true,
      "allow": ["main"]
    },
    "sessions": {
      "visibility": "all"
    },
    "web": {
      "search": {
        "apiKey": "${BRAVE_API_KEY}"
      }
    }
  },
  "messages": {
    "ackReactionScope": "group-mentions"
  },
  "commands": {
    "native": "auto",
    "nativeSkills": "auto",
    "restart": true,
    "ownerDisplay": "raw"
  },
  "cron": {
    "enabled": true,
    "maxConcurrentRuns": 2
  },
  "channels": {
    "telegram": {
      "enabled": true,
      "accounts": {
        "default": {
          "botToken": "${TELEGRAM_BOT_TOKEN}",
          "dmPolicy": "pairing",
          "groupPolicy": "allowlist",
          "streamMode": "partial"
        }
      }
    },
    "mattermost": {
      "enabled": true,
      "dmPolicy": "pairing"
    }
  },
  "gateway": {
    "port": 18789,
    "mode": "local",
    "bind": "lan",
    "tls": { "enabled": true },
    "controlUi": {
      "allowedOrigins": [
        "https://10.17.1.40:18789",
        "https://100.64.0.10:18789"
      ]
    },
    "auth": {
      "mode": "token",
      "token": "${OPENCLAW_GATEWAY_TOKEN}"
    },
    "tailscale": {
      "mode": "off",
      "resetOnExit": false
    },
    "remote": { "url": "wss://100.64.0.10:18789" },
    "nodes": {
      "denyCommands": [
        "camera.snap",
        "camera.clip",
        "screen.record",
        "calendar.add",
        "contacts.add",
        "reminders.add"
      ]
    }
  },
  "skills": {
    "install": {
      "nodeManager": "npm"
    }
  },
  "plugins": {
    "entries": {
      "telegram": {
        "enabled": true
      },
      "mattermost": {
        "enabled": true
      }
    }
  }
}
